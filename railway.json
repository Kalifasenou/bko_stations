{
  "$schema": "https://railway.app/json-schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile",
    "watchPaths": ["backend/**"]
  },
  "deploy": {
    "healthcheckPath": "/api/health/",
    "restartPolicy": {
      "type": "ON_FAILURE",
      "maxRetries": 10
    }
  }
}
