# Django Configuration
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration (used by settings.py)
DATABASE_URL=sqlite:///db.sqlite3
# Example PostgreSQL:
# DATABASE_URL=postgres://postgres:password@localhost:5432/bko_station

# Optional cache URL (Redis in production)
# REDIS_URL=redis://127.0.0.1:6379/1

# Security (production defaults)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO

# Optional: auto-create superuser in start.sh (production)
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Optional: create admin when running seed_stations.py (local/demo)
SEED_ADMIN_USERNAME=
SEED_ADMIN_EMAIL=admin@bko-stations.local
SEED_ADMIN_PASSWORD=
